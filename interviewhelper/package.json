{
  "name": "suntrenia-ai-intervia-helper",
  "version": "1.0.0",
  "description": "Chrome extension for AI-powered interview coaching integrated with IntelliJob",
  "main": "background.js",
  "scripts": {
    "build": "echo 'Extension built successfully'",
    "test": "node test-extension.js",
    "lint": "echo 'No linting configured'"
  },
  "keywords": [
    "chrome-extension",
    "interview-coaching",
    "ai",
    "job-search",
    "career-development"
  ],
  "author": "IntelliJob Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "."
  },
  "devDependencies": {},
  "extension": {
    "manifest_version": 3,
    "permissions": [
      "activeTab",
      "storage",
      "scripting",
      "cookies"
    ],
    "host_permissions": [
      "http://localhost:3000/*",
      "https://your-domain.com/*"
    ]
  }
}